{
    "manifest_version" : 3,
    "name" : "Pomodoro App",
    "version" : "1.0",
    "description" : "A minimal Pomodoro timer extension.",
    "action" : {
        "default_popup" : "popup.html",
        "default_title" : "Pomodoro App"
    },
    "background" : {
        "service_worker": "background.js"
    },
    "permissions" : ["storage","notifications"],
    "icons" : {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128" : "icons/icon128.png"
    }
}